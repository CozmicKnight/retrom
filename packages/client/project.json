{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "retrom-client",
  "implicitDependencies": ["retrom-client-web"],
  "targets": {
    "cargo:lint": {},
    "cargo:format": {},
    "dev": {
      "dependsOn": ["retrom-client-web:dev:desktop"],
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "node ./scripts/nodew.mjs ./scripts/tauriw.mjs dev --no-watch"
      }
    },
    "build": {
      "dependsOn": ["retrom-client-web:build:desktop"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "node ./scripts/nodew.mjs ./scripts/tauriw.mjs build"
      },
      "defaultConfiguration": "release",
      "configurations": {
        "release": {
          "command": "node ./scripts/nodew.mjs ./scripts/tauriw.mjs build --config tauri.build.conf.json"
        },
        "debug": {
          "command": "node ./scripts/nodew.mjs ./scripts/tauriw.mjs build --debug"
        }
      }
    }
  }
}
